    sbg.Position = UDim2.new(0.05, 0, 0, 28)
    sbg.BackgroundColor3 = Color3.fromRGB(42, 42, 55)
    sbg.BorderSizePixel = 0
    local sc = Instance.new("UICorner")
    sc.CornerRadius = UDim.new(1, 0)
    sc.Parent = sbg
    
    local sfill = Instance.new("Frame")
    local pct = (default - min) / (max - min)
    sfill.Size = UDim2.new(pct, 0, 1, 0)
    sfill.BackgroundColor3 = Color3.fromRGB(70, 130, 255)
    sfill.BorderSizePixel = 0
    local sfc = Instance.new("UICorner")
    sfc.CornerRadius = UDim.new(1, 0)
    sfc.Parent = sfill
    sfill.Parent = sbg
    
    local sbtn = Instance.new("TextButton")
    sbtn.Size = UDim2.new(1, 0, 1, 0)
    sbtn.BackgroundTransparency = 1
    sbtn.Text = ""
    sbtn.Parent = sbg
    
    local sliding = false
    
    local function upd(inpPos)
        local ax = sbg.AbsolutePosition.X
        local aw = sbg.AbsoluteSize.X
        local p = math.clamp((inpPos - ax) / aw, 0, 1)
        local v = math.floor(min + (max - min) * p)
        v = math.clamp(v, min, max)
        _G.S[varName] = v
        vlbl.Text = tostring(v)
        sfill.Size = UDim2.new(p, 0, 1, 0)
        
        -- Real-time update for active features
        if varName == "FlySpeed" and _G.S.Fly then end
        if varName == "WalkSpeed" and _G.S.Speed then
            local c = player.Character
            if c and c:FindFirstChild("Humanoid") then c.Humanoid.WalkSpeed = v end
        end
        if varName == "FlingPower" and _G.S.Fling then end
    end
    
    sbtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then
            sliding = true
            upd(inp.Position)
        end
    end)
    sbtn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then sliding = false end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if sliding and inp.UserInputType == Enum.UserInputType.Touch then upd(inp.Position) end
    end)
    
    f.Parent = rightPanel
    return f
end

function ShowFeatureSettings(featureId, featureName)
    ClearRightPanel()
    rpTitle.Text = featureName
    
    if featureId == "fly" then
        CreateToggleSetting("Fly", "Fly")
        CreateSliderSetting("Fly Speed", "FlySpeed", 10, 200, 50)
    elseif featureId == "speed" then
        CreateToggleSetting("Speed", "Speed")
        CreateSliderSetting("Walk Speed", "WalkSpeed", 16, 250, 16)
    elseif featureId == "noclip" then
        CreateToggleSetting("Noclip", "Noclip")
    elseif featureId == "fling" then
        CreateToggleSetting("Fling", "Fling")
        CreateSliderSetting("Fling Power", "FlingPower", 50, 500, 100)
    elseif featureId == "esp" then
        CreateToggleSetting("ESP Players", "ESP")
        CreateToggleSetting("Line", "Line")
        CreateToggleSetting("Box", "Box")
        CreateToggleSetting("Name", "NameTag")
        CreateToggleSetting("Highlight", "Highlight")
        CreateToggleSetting("Studs", "Studs")
    elseif featureId == "invisible" then
        CreateToggleSetting("Invisible", "Invisible")
    elseif featureId == "fps" then
        CreateToggleSetting("FPS Boost", "FPS")
    end
end

