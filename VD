-- Icon Drag
local drag = false
local dStart, iStart

icon.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.Touch then
        drag = true
        dStart = inp.Position
        iStart = icon.Position
    end
end)

icon.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.Touch then drag = false end
end)

UIS.InputChanged:Connect(function(inp)
    if drag and inp.UserInputType == Enum.UserInputType.Touch then
        local d = inp.Position - dStart
        local v = Cam.ViewportSize
        icon.Position = UDim2.new(0, math.clamp(iStart.X.Offset + d.X, 0, v.X - 50), 0, math.clamp(iStart.Y.Offset + d.Y, 0, v.Y - 50))
    end
end)

