    sbtn.Size = UDim2.new(1, 0, 1, 0)
    sbtn.BackgroundTransparency = 1
    sbtn.Text = ""
    sbtn.Parent = sbg
    
    local sliding = false
    
    local function upd(pos)
        local ax = sbg.AbsolutePosition.X
        local aw = sbg.AbsoluteSize.X
        local p = math.clamp((pos - ax) / aw, 0, 1)
        local v = math.floor(min + (max - min) * p)
        v = math.clamp(v, min, max)
        _G.S[var] = v
        vl.Text = tostring(v)
        sf.Size = UDim2.new(p, 0, 1, 0)
        
        -- Real-time update
        if var == "WalkSpeed" and _G.S.Speed then
            local c = plr.Character
            if c and c:FindFirstChild("Humanoid") then c.Humanoid.WalkSpeed = v end
        end
    end
    
    sbtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then
            sliding = true
            upd(inp.Position)
        end
    end)
    sbtn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then sliding = false end
    end)
    UIS.InputChanged:Connect(function(inp)
        if sliding and inp.UserInputType == Enum.UserInputType.Touch then upd(inp.Position) end
    end)
    
    f.Parent = rightP
end

