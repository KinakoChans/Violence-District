-- ============== FEATURE FUNCTIONS - FIXED ==============

function RunFeature(var, state)
    if var == "Fly" then
        if state then StartFly() else StopFly() end
    elseif var == "Speed" then
        if state then StartSpeed() else StopSpeed() end
    elseif var == "Noclip" then
        if state then StartNoclip() else StopNoclip() end
    elseif var == "Fling" then
        if state then StartFling() else StopFling() end
    elseif var == "Invisible" then
        if state then StartInvisible() else StopInvisible() end
    elseif var == "FPS" then
        if state then StartFPS() else StopFPS() end
    elseif var == "ESP" then
        if state then StartESP() else StopESP() end
    end
end

-- ===== FLY =====
function StartFly()
    local c = plr.Character
    if not c then return end
    local h = c:FindFirstChild("HumanoidRootPart")
    if not h then return end
    if c:FindFirstChild("Humanoid") then c.Humanoid.PlatformStand = true end
    
    _G.C.Fly = RS.RenderStepped:Connect(function()
        if not _G.S.Fly then return end
        local c2 = plr.Character
        if not c2 then return end
        local h2 = c2:FindFirstChild("HumanoidRootPart")
        if not h2 then return end
        
        local dir = Vector3.new()
        if UIS:IsKeyDown(Enum.KeyCode.W) then dir = dir + Cam.CFrame.LookVector * Vector3.new(1,0,1) end
        if UIS:IsKeyDown(Enum.KeyCode.S) then dir = dir - Cam.CFrame.LookVector * Vector3.new(1,0,1) end
        if UIS:IsKeyDown(Enum.KeyCode.A) then dir = dir - Cam.CFrame.RightVector * Vector3.new(1,0,1) end
        if UIS:IsKeyDown(Enum.KeyCode.D) then dir = dir + Cam.CFrame.RightVector * Vector3.new(1,0,1) end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0,1,0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir + Vector3.new(0,-1,0) end
        
        -- Mobile touch controls
        for _, t in ipairs(UIS:GetTouchInputs()) do
            local sx = t.Position.X / Cam.ViewportSize.X
            local sy = t.Position.Y / Cam.ViewportSize.Y
            if sx < 0.5 then
                local dx, dy = sx - 0.25, sy - 0.5
                if math.abs(dy) > 0.12 then dir = dir + Vector3.new(0, 0, -dy * 3) end
                if math.abs(dx) > 0.12 then dir = dir + Vector3.new(dx * 3, 0, 0) end
            else
                if sy < 0.3 then dir = dir + Vector3.new(0, 1, 0)
                elseif sy > 0.7 then dir = dir + Vector3.new(0, -1, 0) end
            end
        end
        
        if dir.Magnitude > 0 then
            dir = dir.Unit * _G.S.FlySpeed
            h2.Velocity = dir
            h2.AssemblyLinearVelocity = dir
        end
    end)
end

function StopFly()
    if _G.C.Fly then _G.C.Fly:Disconnect() _G.C.Fly = nil end
    local c = plr.Character
    if c and c:FindFirstChild("Humanoid") then c.Humanoid.PlatformStand = false end
end

-- ===== SPEED =====
function StartSpeed()
    _G.C.Speed = RS.RenderStepped:
