-- ===== SMOOTH ICON DRAG =====
local isDragging = false
local dragStart, iconStart

icon.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        isDragging = true
        dragStart = input.Position
        iconStart = icon.Position
    end
end)

icon.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        isDragging = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if isDragging and input.UserInputType == Enum.UserInputType.Touch then
        local delta = input.Position - dragStart
        local viewSize = Cam.ViewportSize
        local newX = math.clamp(iconStart.X.Offset + delta.X, 0, viewSize.X - 50)
        local newY = math.clamp(iconStart.Y.Offset + delta.Y, 0, viewSize.Y - 50)
        icon.Position = UDim2.new(0, newX, 0, newY)
    end
end)

