-- ============== FEATURE FUNCTIONS ==============

function TriggerFeature(varName, state)
    if varName == "Fly" then ToggleFly(state) end
    if varName == "Speed" then ToggleSpeed(state) end
    if varName == "Noclip" then ToggleNoclip(state) end
    if varName == "Fling" then ToggleFling(state) end
    if varName == "Invisible" then ToggleInvisible(state) end
    if varName == "FPS" then ToggleFPS(state) end
    if varName == "ESP" then ToggleESP(state) end
end

-- FLY
function ToggleFly(state)
    if state then
        local char = player.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        if char:FindFirstChild("Humanoid") then char.Humanoid.PlatformStand = true end
        
        _G.C.Fly = RunService.RenderStepped:Connect(function()
            if not _G.S.Fly then return end
            local c = player.Character
            if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart")
            if not h then return end
            
            local dir = Vector3.new()
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + Camera.CFrame.LookVector * Vector3.new(1,0,1) end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - Camera.CFrame.LookVector * Vector3.new(1,0,1) end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - Camera.CFrame.RightVector * Vector3.new(1,0,1) end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + Camera.CFrame.RightVector * Vector3.new(1,0,1) end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir + Vector3.new(0,-1,0) end
            
            -- Mobile touch
            for _, t in ipairs(UserInputService:GetTouchInputs()) do
                local sx = t.Position.X / Camera.ViewportSize.X
                local sy = t.Position.Y / Camera.ViewportSize.Y
                if sx < 0.5 then
                    local dx, dy = sx - 0.25, sy - 0.5
                    if math.abs(dy) > 0.12 then dir = dir + Vector3.new(0,0,-dy*3) end
                    if math.abs(dx) > 0.12 then dir = dir + Vector3.new(dx*3,0,0) end
                else
                    if sy < 0.3 then dir = dir + Vector3.new(0,1,0)
                    elseif sy > 0.7 then dir = dir + Vector3.new(0,-1,0) end
                end
            end
            
            if dir.Magnitude > 0 then dir = dir.Unit * _G.S.FlySpeed end
            h.Velocity = dir
            h.AssemblyLinearVelocity = dir
        end)
    else
        if _G.C.Fly then _G.C.Fly:Disconnect() _G.C.Fly = nil end
        local c = player.Character
        if c and c:FindFirstChild("Humanoid") then c.Humanoid.PlatformStand = false end
    end
end

-- SPEED
function ToggleSpeed(state)
    if state then
        _G.C.Speed = RunService.RenderStepped:Connect(function()
            if not _G.S.Speed then return end
            local c = player.Character
            if c and c:FindFirstChild("Humanoid") then c.Humanoid.WalkSpeed = _G.S.WalkSpeed end
        end)
    else
        if _G.C.Speed then _G.C.Speed:Disconnect() _G.C.Speed = nil end
        local c = player.Character
        if c and c:FindFirstChild("Humanoid") then c.Humanoid.WalkSpeed = 16 end
    end
end

-- NOCLIP
function ToggleNoclip(state)
    if state then
        _G.C.Noclip = RunService.Stepped:Connect(function()
            if not _G.S.Noclip then return end
            local c = player.Character
            if not c then return end
            for _, p in ipairs(c:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
        end)
    else
        if _G.C.Noclip then _G.C.Noclip:Disconnect() _G.C.Noclip = nil end
    end
end

-- FLING
function ToggleFling(state)
    if state then
        _G.C.Fling = RunService.Stepped:Connect(function()
            if not _G.S.Fling then return end
            local c = player.Character
            if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart")
            if not h then return end
            
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player then
                    local oc = p.Character
                    if oc and oc:FindFirstChild("HumanoidRootPart") then
                        local oh = oc.HumanoidRootPart
                        if (h.Position - oh.Position).Magnitude < 12 then
                            oh.Velocity = (oh.Position - h.Position).Unit * _G.S.FlingPower
                        end
                    end
                end
            end
        end)
    else
        if _G.C.Fling then _G.C.Fling:Disconnect() _G.C.Fling = nil end
    end
end

-- INVISIBLE
_G.InvisPos = CFrame.new(0, 5, 0)

function ToggleInvisible(state)
    local c = player.Character
    if not c then return end
    
    if state then
        _G.InvisPos = c:GetPrimaryPartCFrame() or CFrame.new(0, 5, 0)
        
        for _, p in ipairs(c:GetDescendants()) do
            if p:IsA("BasePart") then
                p.CFrame = CFrame.new(0, -99999, 0)
                p.Transparency = 1
                p.CanCollide = false
            end
        end
        
        Camera.CameraType = Enum.CameraType.Scriptable
        Camera.CFrame = _G.InvisPos
        
        _G.C.Invis = RunService.RenderStepped:Connect(function()
            if not _G.S.Invisible then return end
            Camera.CFrame = _G.InvisPos
        end)
    else
        if _G.C.Invis then _G.C.Invis:Disconnect() _G.C.Invis = nil end
        
        local c2 = player.Character
        if c2 then
            c2:SetPrimaryPartCFrame(_G.InvisPos)
            for _, p in ipairs(c2:GetDescendants()) do
                if p:IsA("BasePart") then p.Transparency = 0 end
            end
            Camera.CameraType = Enum.CameraType.Custom
            if c2:FindFirstChild("Humanoid") then Camera.CameraSubject = c2.Humanoid end
        end
    end
end

-- FPS BOOST
function ToggleFPS(state)
    if state then
        Lighting.GlobalShadows = false
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Fire") then
                v.Enabled = false
            end
        end
    else
        Lighting.GlobalShadows = true
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
    end
end

-- ESP
_G.ESPData = {}
_G.ESPItems = {}

function ToggleESP(state)
    if state then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player then CreateESP(p) end
        end
        
        Players.PlayerAdded:Connect(function(p)
            if p ~= player then
                p.CharacterAdded:Connect(function()
                    task.wait(0.5)
                    if _G.S.ESP then CreateESP(p) end
                end)
            end
        end)
        
        _G.C.ESP = RunService.RenderStepped:Connect(UpdateESP)
    else
        if _G.C.ESP then _G.C.ESP:Disconnect() _G.C.ESP = nil end
        for _, item in ipairs(_G.ESPItems) do pcall(function() item:Destroy() end) end
        _G.ESPItems = {}
        _G.ESPData = {}
    end
end

function CreateESP(targetPlayer)
    targetPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        if _G.S.ESP then AddESP(targetPlayer, char) end
    end)
    if targetPlayer.Character then AddESP(targetPlayer, targetPlayer.Character) end
end

function AddESP(targetPlayer, char)
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Name
    local ng = Instance.new("BillboardGui")
    ng.Name = "E_Name"
    ng.Size = UDim2.new(0, 140, 0, 22)
    ng.StudsOffset = Vector3.new(0, 3.5, 0)
    ng.AlwaysOnTop = true
    ng.Adornee = hrp
    local nl = Instance.new("TextLabel")
    nl.Size = UDim2.new(1,0,1,0)
    nl.BackgroundTransparency = 1
    nl.Text = targetPlayer.Name
    nl.TextColor3 = Color3.new(1,1,1)
    nl.TextSize = 12
    nl.Font = Enum.Font.GothamBold
    nl.TextStrokeTransparency = 0.3
    nl.Parent = ng
    ng.Parent = hrp
    table.insert(_G.ESPItems, ng)
    
    -- Box
    local bg = Instance.new("BillboardGui")
    bg.Name = "E_Box"
    bg.Size = UDim2.new(0, 4, 0, 6)
    bg.StudsOffset = Vector3.new(0, 2.5, 0)
    bg.AlwaysOnTop = true
    bg.Adornee = hrp
    local bf = Instance.new("Frame")
    bf.Size = UDim2.new(1,0,1,0)
    bf.BackgroundTransparency = 1
    bf.BorderSizePixel = 1
    bf.BorderColor3 = Color3.fromRGB(255, 50, 50)
    bf.Parent = bg
    bg.Parent = hrp
    table.insert(_G.ESPItems, bg)
    
    -- Highlight
    local hl = Instance.new("Highlight")
    hl.Name = "E_Highlight"
    hl.Adornee = char
    hl.FillColor = Color3.fromRGB(255, 50, 50)
    hl.FillTransparency = 0.65
    hl.OutlineColor = Color3.new(1,1,1)
    hl.OutlineTransparency = 0.5
    hl.Parent = char
    table.insert(_G.ESPItems, hl)
    
    -- Line
    local ln = Instance.new("Part")
    ln.Name = "E_Line_" .. targetPlayer.Name
    ln.Size = Vector3.new(0.15, 0.15, 1)
    ln.Color = Color3.fromRGB(255, 50, 50)
    ln.Material = Enum.Material.Neon
    ln.Anchored = true
    ln.CanCollide = false
    ln.Transparency = 0.4
    ln.Parent = Workspace
    table.insert(_G.ESPItems, ln)
    
    _G.ESPData[targetPlayer] = {Char = char, HRP = hrp, Line = ln, Box = bg, Name = ng, Highlight = hl}
end

function UpdateESP()
    if not _G.S.ESP then return end
    
    for p, data in pairs(_G.ESPData) do
        if data.HRP then
            -- Line
            if _G.S.Line and data.Line then
                local cp = Camera.CFrame.Position
                local tp = data.HRP.Position
                local d = (cp - tp).Magnitude
                data.Line.Size = Vector3.new(0.15, 0.15, d)
                data.Line.CFrame = CFrame.lookAt((cp+tp)/2, tp) * CFrame.new(0,0,-d/2)
                data.Line.Visible = true
            elseif data.Line then
                data.Line.Visible = false
            end
            
            -- Box
            if data.Box then data.Box.Enabled = _G.S.Box end
            
            -- Name
            if data.Name then data.Name.Enabled = _G.S.NameTag end
            
            -- Highlight
            if data.Highlight then data.Highlight.Enabled = _G.S.Highlight end
            
            -- Studs
            if _G.S.Studs then
                local d = math.floor((Camera.CFrame.Position - data.HRP.Position).Magnitude)
                local sg2 = data.HRP:FindFirstChild("E_Studs")
                if not sg2 then
                    sg2 = Instance.new("BillboardGui")
                    sg2.Name = "E_Studs"
                    sg2.Size = UDim2.new(0, 70, 0, 16)
                    sg2.StudsOffset = Vector3.new(0, -2, 0)
                    sg2.AlwaysOnTop = true
                    sg2.Adornee = data.HRP
                    local sl = Instance.new("TextLabel")
                    sl.Size = UDim2.new(1,0,1,0)
                    sl.BackgroundTransparency = 1
                    sl.TextColor3 = Color3.fromRGB(255, 255, 100)
                    sl.TextSize = 10
                    sl.Font = Enum.Font.Gotham
                    sl.TextStrokeTransparency = 0.4
                    sl.Parent = sg2
                    sg2.Parent = data.HRP
                    table.insert(_G.ESPItems, sg2)
                end
                sg2.Enabled = true
                local lbl = sg2:FindFirstChildOfClass("TextLabel")
                if lbl then lbl.Text = tostring(d) .. "s" end
            else
                local sg2 = data.HRP:FindFirstChild("E_Studs")
                if sg2 then sg2.Enabled = false end
            end
        end
    end
end

