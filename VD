-- FLING FUNCTION
function applyFling(char)
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("HumanoidRootPart") then
                local otherHRP = otherChar.HumanoidRootPart
                local dist = (hrp.Position - otherHRP.Position).Magnitude
                if dist < 10 then
                    local direction = (otherHRP.Position - hrp.Position).Unit
                    otherHRP.Velocity = direction * _G.FlingPower
                    otherHRP.AssemblyLinearVelocity = direction * _G.FlingPower
                end
            end
        end
    end
end

-- INVISIBLE FUNCTION
function applyInvisible(char)
    if not char then return end
    
    -- Save current character position
    _G.OriginalCF = char:GetPrimaryPartCFrame() or CFrame.new()
    
    -- Move character parts deep underground
    local undergroundPos = CFrame.new(0, -99999, 0)
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CFrame = undergroundPos
            part.Transparency = 1
            -- Keep CanCollide to prevent falling
        end
    end
    
    -- Make humanoid invisible
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
    end
    
    -- Keep camera at current position (POV stays)
    Camera.CameraSubject = char:FindFirstChild("Humanoid")
    
    -- Prevent character from dying
    local humanoid2 = char:FindFirstChild("Humanoid")
    if humanoid2 then
        humanoid2.BreakJointsOnDeath = false
    end
    
    -- Create a fake part to keep camera
    local fakePart = Instance.new("Part")
    fakePart.Name = "FakeCameraPart"
    fakePart.Size = Vector3.new(1, 1, 1)
    fakePart.Transparency = 1
    fakePart.CanCollide = false
    fakePart.Anchored = true
    fakePart.CFrame = _G.OriginalCF
    fakePart.Parent = workspace
    
    -- Lock camera to fake part
    task.wait(0.1)
    Camera.CameraType = Enum.CameraType.Scriptable
    Camera.CFrame = _G.OriginalCF
    
    _G.FakePart = fakePart
    
    _G.InvisibleConnection = RunService.RenderStepped:Connect(function()
        if _G.InvisibleEnabled and _G.FakePart then
            -- Keep character parts underground
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "FakeCameraPart" then
                    part.CFrame = undergroundPos
                    part.Transparency = 1
                end
            end
            -- Keep camera at original position
            Camera.CFrame = _G.FakePart.CFrame
        end
    end)
end

function disableInvisible(char)
    if _G.InvisibleConnection then
        _G.InvisibleConnection:Disconnect()
        _G.InvisibleConnection = nil
    end
    
    if _G.FakePart then
        _G.FakePart:Destroy()
        _G.FakePart = nil
    end
    
    if not char then return end
    
    -- Restore character
    if _G.OriginalCF then
        char:SetPrimaryPartCFrame(_G.OriginalCF)
    end
    
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 0
        end
    end
    
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.Subject
        humanoid.BreakJointsOnDeath = true
    end
    
    Camera.CameraType = Enum.CameraType.Custom
    Camera.CameraSubject = humanoid
end

-- ESP FUNCTION
local ESPObjects = {}

function setupESP()
    -- Create ESP for all players
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            createESPForPlayer(otherPlayer)
        end
    end
    
    Players.PlayerAdded:Connect(function(newPlayer)
        if newPlayer ~= player then
            newPlayer.CharacterAdded:Connect(function()
                if _G.ESPEnabled then
                    createESPForPlayer(newPlayer)
                end
            end)
        end
    end)
    
    _G.ESPConnection = RunService.RenderStepped:Connect(function()
        if not _G.ESPEnabled then return end
        updateESP()
    end)
end

function createESPForPlayer(targetPlayer)
    local espData = {}
    espData.Player = targetPlayer
    espData.Objects = {}
    
    -- Create ESP objects conditionally based on toggles
    targetPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        if _G.ESPEnabled then
            espData.Char = char
            updateESPObjects(espData)
        end
    end)
    
    if targetPlayer.Character then
        espData.Char = targetPlayer.Character
    end
    
    table.insert(ESPObjects, espData)
end

function updateESPObjects(espData)
    local char = espData.Char
    if not char then return end
    
    -- Clean existing
    for _, obj in ipairs(espData.Objects) do
        pcall(function() obj:Destroy() end)
    end
    espData.Objects = {}
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Box
    if _G.BoxEnabled then
        local box = Instance.new("BillboardGui")
        box.Name = "ESPBox"
        box.Size = UDim2.new(0, 4, 0, 6)
        box.StudsOffset = Vector3.new(0, 3, 0)
        box.AlwaysOnTop = true
        box.Adornee = hrp
        box.Parent = hrp
        
        local outline = Instance.new("Frame")
        outline.Size = UDim2.new(1, 0, 1, 0)
        outline.BackgroundTransparency = 1
        outline.BorderSizePixel = 1
        outline.BorderColor3 = Color3.fromRGB(255, 50, 50)
        outline.Parent = box
        table.insert(espData.Objects, box)
    end
    
    -- Name
    if _G.NameEnabled then
        local nameGui = Instance.new("BillboardGui")
        nameGui.Name = "ESPName"
        nameGui.Size = UDim2.new(0, 200, 0, 30)
        nameGui.StudsOffset = Vector3.new(0, 4, 0)
        nameGui.AlwaysOnTop = true
        nameGui.Adornee = hrp
        nameGui.Parent = hrp
        
        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, 0, 1, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = espData.Player.Name
        nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        nameLabel.TextSize = 14
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextStrokeTransparency = 0.5
        nameLabel.Parent = nameGui
        table.insert(espData.Objects, nameGui)
    end
    
    -- Highlight
    if _G.HighlightEnabled then
        local highlight = Instance.new("Highlight")
        highlight.Name = "ESPHighlight"
        highlight.Adornee = char
        highlight.FillColor = Color3.fromRGB(255, 50, 50)
        highlight.FillTransparency = 0.7
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.OutlineTransparency = 0.5
        highlight.Parent = char
        table.insert(espData.Objects, highlight)
    end
end

function updateESP()
    for _, espData in ipairs(ESPObjects) do
        local char = espData.Player.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                -- Line (draw from camera to player)
                if _G.LineEnabled then
                    -- Simple line using a part (can be improved with Drawing API)
                    local linePart = workspace:FindFirstChild("ESPLine_" .. espData.Player.Name)
                    if not linePart then
                        linePart = Instance.new("Part")
                        linePart.Name = "ESPLine_" .. espData.Player.Name
                        linePart.Size = Vector3.new(0.2, 0.2, 1)
                        linePart.Color = Color3.fromRGB(255, 50, 50)
                        linePart.Material = Enum.Material.Neon
                        linePart.Anchored = true
                        linePart.CanCollide = false
                        linePart.Transparency = 0.5
                        linePart.Parent = workspace
                    end
                    
                    local camPos = Camera.CFrame.Position
                    local targetPos = hrp.Position
                    local midPoint = (camPos + targetPos) / 2
                    local dist = (camPos - targetPos).Magnitude
                    
                    linePart.Size = Vector3.new(0.2, 0.2, dist)
                    linePart.CFrame = CFrame.lookAt(midPoint, targetPos) * CFrame.new(0, 0, -dist/2)
                    linePart.Visible = _G.LineEnabled
                else
                    local linePart = workspace:FindFirstChild("ESPLine_" .. espData.Player.Name)
                    if linePart then
                        linePart.Visible = false
                    end
                end
                
                -- Studs
                if _G.StudsEnabled then
                    local dist = math.floor((Camera.CFrame.Position - hrp.Position).Magnitude)
                    local studGui = char:FindFirstChild("StudsGui") or char:FindFirstChild("HumanoidRootPart"):FindFirstChild("StudsGui")
                    if not studGui then
                        studGui = Instance.new("BillboardGui")
                        studGui.Name = "StudsGui"
                        studGui.Size = UDim2.new(0, 100, 0, 20)
                        studGui.StudsOffset = Vector3.new(0, -2, 0)
                        studGui.AlwaysOnTop = true
                        studGui.Adornee = hrp
                        studGui.Parent = hrp
                        
                        local studLabel = Instance.new("TextLabel")
                        studLabel.Size = UDim2.new(1, 0, 1, 0)
                        studLabel.BackgroundTransparency = 1
                        studLabel.Text = tostring(dist) .. " studs"
                        studLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
                        studLabel.TextSize = 12
                        studLabel.Font = Enum.Font.Gotham
                        studLabel.TextStrokeTransparency = 0.5
                        studLabel.Parent = studGui
                    end
                    studGui.Enabled = true
                    if studGui:FindFirstChildOfClass("TextLabel") then
                        studGui:FindFirstChildOfClass("TextLabel").Text = tostring(dist) .. " studs"
                    end
                else
                    local studGui = hrp and hrp:FindFirstChild("StudsGui")
                    if studGui then
                        studGui.Enabled = false
                    end
                end
            end
        end
    end
end

function disableESP()
    if _G.ESPConnection then
        _G.ESPConnection:Disconnect()
        _G.ESPConnection = nil
    end
    
    -- Clean up ESP objects
    for _, espData in ipairs(ESPObjects) do
        for _, obj in ipairs(espData.Objects) do
            pcall(function() obj:Destroy() end)
        end
    end
    ESPObjects = {}
    
    -- Clean up line parts
    for _, v in ipairs(workspace:GetChildren()) do
        if v.Name and string.find(v.Name, "ESPLine_") then
            v:Destroy()
        end
    end
end

-- FPS BOOST FUNCTION
function applyFPSBoost()
    -- Disable shadows
    Lighting.GlobalShadows = false
    
    -- Lower quality
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    
    -- Disable terrain
    workspace.Terrain.WaterWaveSize = 0
    workspace.Terrain.WaterWaveSpeed = 0
    
    -- Disable particles
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
            v.Enabled = false
        end
    end
    
    -- Set FPS cap
    setfpscap(60)
end

function disableFPSBoost()
    Lighting.GlobalShadows = true
    settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
    workspace.Terrain.WaterWaveSize = 0.5
    workspace.Terrain.WaterWaveSpeed = 5
    setfpscap(60)
end

