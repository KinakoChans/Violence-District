end)

-- ============== ESP SYSTEM ==============
local ESPObjects = {}

local function ClearESP()
    for obj, highlight in pairs(ESPObjects) do
        pcall(function()
            highlight:Destroy()
        end)
    end
    ESPObjects = {}
end

local function CreateESP(obj, color)
    if not obj or ESPObjects[obj] then return end
    
    local highlight = Instance.new("Highlight")
    highlight.FillColor = color
    highlight.OutlineColor = color
    highlight.FillTransparency = 0.6
    highlight.OutlineTransparency = 0.2
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = obj
    
    ESPObjects[obj] = highlight
    
    obj.AncestryChanged:Connect(function()
        if not obj.Parent then
            if ESPObjects[obj] then
                ESPObjects[obj]:Destroy()
                ESPObjects[obj] = nil
            end
        end
    end)
end

local function UpdateESP()
    while task.wait(0.3) do
        if not Settings.ESP.Survivor and not Settings.ESP.Killer and not Settings.ESP.Generator then
            ClearESP()
            continue
        end
        
        local myChar = LocalPlayer.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        
        -- Player ESP
        for _, player in pairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            if not player.Character then continue end
            
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            
            -- Distance check
            if myRoot then
                local dist = (root.Position - myRoot.Position).Magnitude
                if dist > Settings.ESP.Distance then continue end
            end
            
            -- Determine if killer (check for knife/weapon)
            local isKiller = false
            for _, child in pairs(player.Character:GetChildren()) do
                if child:IsA("Tool") or child.Name:lower():find("knife") or child.Name:lower():find("blade") then
                    isKiller = true
                    break
                end
            end
            
            if isKiller and Settings.ESP.Killer then
                CreateESP(player.Character, Color3.fromRGB(255, 60, 60))
            elseif not isKiller and Settings.ESP.Survivor then
                CreateESP(player.Character, Color3.fromRGB(60, 255, 120))
            end
        end
        
        -- Generator ESP
        if Settings.ESP.Generator then
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj.Name:lower():find("generator") or obj.Name:lower():find("gen") then
                    if obj:IsA("BasePart") or obj:IsA("Model") then
                        if myRoot then
                            local dist = (obj.Position - myRoot.Position).Magnitude
                            if dist <= Settings.ESP.Distance then
                                CreateESP(obj, Color3.fromRGB(255, 170, 0))
                            end
                        end
                    end
                end
            end
        end
    end
end

-- ============== PLAYER MODS ==============
local function ApplyWalkspeed()
    while task.wait(0.1) do
        if not Settings.Player.Walkspeed then task.wait(1) continue end
        
        local char = LocalPlayer.Character
        if not char then continue end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = Settings.Player.WalkspeedValue
        end
    end
end

local function ApplyJumpPower()
    while task.wait(0.1) do
        if not Settings.Player.JumpPower then task.wait(1) continue end
        
        local char = LocalPlayer.Character
        if not char then continue end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.JumpPower = Settings.Player.JumpPowerValue
        end
    end
end

local function ApplyNoClip()
    while task.wait(0.1) do
        if not Settings.Player.NoClip then task.wait(1) continue end
        
        local char = LocalPlayer.Character
        if not char then continue end
        
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end

-- ============== AUTO FEATURES ==============
local function AutoParry()
    while task.wait(0.05) do
        if not Settings.Auto.Parry then task.wait(1) continue end
        
        local char = LocalPlayer.Character
        if not char then continue end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then continue end
        
        -- Check if health dropped (being attacked)
        if hum.Health < hum.MaxHealth * 0.95 then
            -- Try to find and fire parry remote
            local remotes = ReplicatedStorage:FindFirstChild("Remotes")
            if remotes then
                for _, folder in pairs(remotes:GetChildren()) do
                    for _, remote in pairs(folder:GetChildren()) do
                        local name = remote.Name:lower()
                        if name:find("parry") or name:find("block") or name:find("defend") then
                            pcall(function()
                                remote:FireServer()
                            end)
                        end
                    end
                end
            end
        end
    end
end

local function AutoSkillCheck()
    while task.wait(0.1) do
        if not Settings.Auto.SkillCheck then task.wait(1) continue end
        
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        if not remotes then continue end
        
        local genRemote = remotes:FindFirstChild("Generator")
        if not genRemote then continue end
        
        for _, remote in pairs(genRemote:GetChildren()) do
            local name = remote.Name:lower()
            if name:find("skillcheck") or name:find("complete") or name:find("result") then
                pcall(function()
                    remote:FireServer(true) -- Perfect skill check
                end)
            end
        end
    end
end

-- ============== KILLER MODE ==============
local function KillAllMode()
    while task.wait(0.5) do
        if not Settings.Killer.KillAll then task.wait(2) continue end
        
        local char = LocalPlayer.Character
        if not char then continue end
        
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        
        for _, player in pairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            if not player.Character then continue end
            
            local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
            if not targetRoot then continue end
            
            local dist = (targetRoot.Position - root.Position).Magnitude
            if dist > Settings.Killer.KillRange then continue end
            
            -- Teleport to target
            root.CFrame = CFrame.new(targetRoot.Position + Vector3.new(0, 3, 0))
            
            -- Try to attack
            local remotes = ReplicatedStorage:FindFirstChild("Remotes")
            if remotes then
                local attackRemote = remotes:FindFirstChild("Attacks")
                if attackRemote then
                    for _, remote in pairs(attackRemote:GetChildren()) do
                        pcall(function()
                            remote:FireServer()
                        end)
                    end
                end
            end
            
            task.wait(0.3)
        end
    end
end

-- ============== VISUAL MODS ==============
local function ApplyFOV()
    while task.wait(0.1) do
        if Settings.Visual.FOV then
            Camera.FieldOfView = Settings.Visual.FOVValue
        end
    end
end

local function ApplyZoom()
    while task.wait(0.1) do
        if Settings.Visual.Zoom then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position + Camera.CFrame.LookVector * Settings.Visual.ZoomValue)
        end
    end
end

