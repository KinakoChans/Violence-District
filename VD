-- ============== GOD MODE (WORKING) ==============
local GodModeConnection = nil

local function ToggleGodMode(state)
    Settings.Player.GodMode = state
    
    if GodModeConnection then
        GodModeConnection:Disconnect()
        GodModeConnection = nil
    end
    
    if state then
        GodModeConnection = RunService.Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            if not char then return end
            
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum then return end
            
            -- Keep health at max
            if hum.Health < hum.MaxHealth then
                hum.Health = hum.MaxHealth
            end
            
            -- Prevent downed state
            if hum:GetState() == Enum.HumanoidStateType.Dead or 
               hum:GetState() == Enum.HumanoidStateType.FallingDown or
               hum:GetState() == Enum.HumanoidStateType.Ragdoll then
                
                pcall(function()
                    hum:ChangeState(Enum.HumanoidStateType.Running)
                end)
            end
            
            -- Remove debuffs
            local attributes = char:GetAttributes()
            if attributes then
                for key, _ in pairs(attributes) do
                    if key:lower():find("down") or key:lower():find("stun") or key:lower():find("slow") then
                        pcall(function()
                            char:SetAttribute(key, nil)
                        end)
                    end
                end
            end
        end)
    end
end

