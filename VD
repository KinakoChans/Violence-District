-- FLY FUNCTION
function setupFly(char)
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    _G.FlyConnection = RunService.RenderStepped:Connect(function()
        if not _G.FlyEnabled or not char or not hrp then
            return
        end
        
        local moveDir = Vector3.new()
        local camCF = Camera.CFrame
        
        -- Get input directions
        local forward = UserInputService:IsKeyDown(Enum.KeyCode.W) or getTouchDirection("up")
        local backward = UserInputService:IsKeyDown(Enum.KeyCode.S) or getTouchDirection("down")
        local left = UserInputService:IsKeyDown(Enum.KeyCode.A) or getTouchDirection("left")
        local right = UserInputService:IsKeyDown(Enum.KeyCode.D) or getTouchDirection("right")
        local up = UserInputService:IsKeyDown(Enum.KeyCode.Space) or getTouchDirection("up2")
        local down = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or getTouchDirection("down2")
        
        if forward then moveDir = moveDir + camCF.LookVector * Vector3.new(1, 0, 1) end
        if backward then moveDir = moveDir - camCF.LookVector * Vector3.new(1, 0, 1) end
        if left then moveDir = moveDir - camCF.RightVector * Vector3.new(1, 0, 1) end
        if right then moveDir = moveDir + camCF.RightVector * Vector3.new(1, 0, 1) end
        if up then moveDir = moveDir + Vector3.new(0, 1, 0) end
        if down then moveDir = moveDir + Vector3.new(0, -1, 0) end
        
        if moveDir.Magnitude > 0 then
            moveDir = moveDir.Unit * _G.FlySpeed
        end
        
        hrp.Velocity = moveDir
        hrp.AssemblyLinearVelocity = moveDir
        
        if char:FindFirstChild("Humanoid") then
            char.Humanoid.PlatformStand = true
        end
    end)
end

function disableFly(char)
    if _G.FlyConnection then
        _G.FlyConnection:Disconnect()
        _G.FlyConnection = nil
    end
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.PlatformStand = false
    end
end

-- Touch direction helper (for mobile)
function getTouchDirection(dir)
    -- Check touch controls (works for mobile)
    local touchInputs = UserInputService:GetTouchInputs()
    for _, input in ipairs(touchInputs) do
        if input.UserInputType == Enum.UserInputType.Touch then
            local screenPos = input.Position
            local screenSize = Camera.ViewportSize
            -- Left half of screen for movement joystick area
            if screenPos.X < screenSize.X / 2 then
                local centerX = screenSize.X / 4
                local centerY = screenSize.Y / 2
                local dx = screenPos.X - centerX
                local dy = screenPos.Y - centerY
                
                if dir == "up" and dy < -50 then return true end
                if dir == "down" and dy > 50 then return true end
                if dir == "left" and dx < -50 then return true end
                if dir == "right" and dx > 50 then return true end
            else
                -- Right half - jump/descend
                if dir == "up2" and (UserInputService:IsKeyDown(Enum.KeyCode.Space) or input.Position.Y < Camera.ViewportSize.Y / 3) then 
                    return true 
                end
                if dir == "down2" and input.Position.Y > Camera.ViewportSize.Y * 2 / 3 then 
                    return true 
                end
            end
        end
    end
    return false
end

