-- ============== FEATURE FUNCTIONS ==============

local speedConnection = nil

function StartSpeed()
    if speedConnection then
        speedConnection:Disconnect()
        speedConnection = nil
    end
    
    speedConnection = RS.RenderStepped:Connect(function()
        if not _G.Hub.Speed then return end
        local c = plr.Character
        if c and c:FindFirstChild("Humanoid") then
            c.Humanoid.WalkSpeed = _G.Hub.SpeedVal
        end
    end)
end

function StopSpeed()
    if speedConnection then
        speedConnection:Disconnect()
        speedConnection = nil
    end
    local c = plr.Character
    if c and c:FindFirstChild("Humanoid") then
        c.Humanoid.WalkSpeed = 16
    end
end

-- Respawn handler
plr.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    if _G.Hub.Speed and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = _G.Hub.SpeedVal
        -- Restart speed loop
        StartSpeed()
    end
end)

