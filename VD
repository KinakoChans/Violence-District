local sliding = false
local minS = 16
local maxS = 250

local function updateSld(pos)
    local ax = sldBg.AbsolutePosition.X
    local aw = sldBg.AbsoluteSize.X
    local pct = math.clamp((pos - ax) / aw, 0, 1)
    local val = math.floor(minS + (maxS - minS) * pct)
    val = math.clamp(val, minS, maxS)
    
    _G.Hub.SpeedVal = val
    sldVal.Text = tostring(val)
    sldLabel.Text = "Speed: " .. tostring(val)
    sldFill.Size = UDim2.new(pct, 0, 1, 0)
    
    if _G.Hub.Speed then
        local c = plr.Character
        if c and c:FindFirstChild("Humanoid") then
            c.Humanoid.WalkSpeed = val
        end
    end
end

sldBtn.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.Touch then
        sliding = true
        updateSld(inp.Position)
    end
end)

sldBtn.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.Touch then
        sliding = false
    end
end)

UIS.InputChanged:Connect(function(inp)
    if sliding and inp.UserInputType == Enum.UserInputType.Touch then
        updateSld(inp.Position)
    end
end)

-- ===== SPEED FUNCTION =====
local spdConn = nil

function EnableSpeed()
    if spdConn then spdConn:Disconnect() end
    spdConn = RS.RenderStepped:Connect(function()
        if not _G.Hub.Speed then return end
        local c = plr.Character
        if c and c:FindFirstChild("Humanoid") then
            c.Humanoid.WalkSpeed = _G.Hub.SpeedVal
        end
    end)
end

function DisableSpeed()
    if spdConn then spdConn:Disconnect() spdConn = nil end
    local c = plr.Character
    if c and c:FindFirstChild("Humanoid") then
        c.Humanoid.WalkSpeed = 16
    end
end

-- Respawn
plr.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    if _G.Hub.Speed and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = _G.Hub.SpeedVal
        EnableSpeed()
    end
end)

